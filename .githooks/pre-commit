#!/bin/sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"

if [ -n "$STAGED_FILES" ]; then
  if printf '%s\n' "$STAGED_FILES" | grep -Eq '(^|/)\.DS_Store$|(^|/)__pycache__/|\.pyc$'; then
    echo "Commit stopped: generated garbage files are staged."
    echo "Please remove .DS_Store, __pycache__, or .pyc files and try again."
    exit 1
  fi

  if printf '%s\n' "$STAGED_FILES" | grep -Eq '^handover/'; then
    echo "Commit stopped: summary files should live in summary/, not handover/."
    exit 1
  fi
fi

echo "Running smoke test before commit..."
npm run smoke
echo "Pre-commit checks passed."
